# ── Copy this file to .env and fill in your real values ──────────────────────
# NEVER commit .env — it is in .gitignore

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Local dev:  postgresql://postgres:yourpassword@127.0.0.1:5432/train_booking
# Railway:    provided automatically as $DATABASE_URL
# Render:     provided automatically as $DATABASE_URL
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@127.0.0.1:5432/train_booking

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a strong secret: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_A_LONG_RANDOM_STRING
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local:   redis://127.0.0.1:6379/0
# Railway: provided as $REDIS_URL
# Render:  provided as $REDIS_URL (add Redis service)
REDIS_URL=redis://127.0.0.1:6379/0
CACHE_TTL_SECONDS=300

# ── RabbitMQ / Celery ─────────────────────────────────────────────────────────
# Local:    amqp://trainapp:trainpass@127.0.0.1:5672/trainvhost
# CloudAMQP (free tier): amqp://user:pass@host/vhost
RABBITMQ_URL=amqp://trainapp:trainpass@127.0.0.1:5672/trainvhost
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1

# ── Elasticsearch ─────────────────────────────────────────────────────────────
# Local:           http://127.0.0.1:9200
# Elastic Cloud:   https://user:pass@your-cluster.es.io:9243
ELASTICSEARCH_URL=http://127.0.0.1:9200
ES_TRAINS_INDEX=trains
ES_STATIONS_INDEX=stations

# ── Email / SMTP ──────────────────────────────────────────────────────────────
# Free testing sandbox: https://mailtrap.io  (free tier)
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=YOUR_MAILTRAP_USER
SMTP_PASS=YOUR_MAILTRAP_PASS
EMAIL_FROM=noreply@trainbooking.com
